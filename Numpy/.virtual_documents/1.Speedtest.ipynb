import numpy as np
import time

# Create big list
list1 = list(range(1000000))   # 10 lakh values

# Python loop-based squaring
start = time.time()
list_squares = []
for x in list1:
    list_squares.append(x ** 2)
end = time.time()
print("Python loop time:", end - start)

# NumPy vectorized squaring
arr1 = np.array(list1)  # convert only once
start = time.time()
numpy_squares = arr1 ** 2
end = time.time()
print("NumPy array time:", end - start)












