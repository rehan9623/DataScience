import numpy as np
import time

# Create two large lists
list1 = list(range(1000000))
list2 = list(range(1000000, 2000000))

start = time.time()
result_list = []
for a, b in zip(list1, list2):
    result_list.append(a * b)
end = time.time()
print("Python list multiplication time:", end - start)

# NumPy 
arr1 = np.array(list1)
arr2 = np.array(list2)

start = time.time()
result_numpy = arr1 * arr2
end = time.time()
print("NumPy array multiplication time:", end - start)






import numpy as np

